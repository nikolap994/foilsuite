---
const github = "https://github.com/nikolap994/foillab"
const path = Astro.url.pathname
const active = (href: string) =>
  href === '/lab' ? path === '/lab' : path === href || path.startsWith(href + '/')
---
<nav class="lab-nav">
  <div class="shell lab-inner">
    <a href="/lab" class:list={['lab-brand mono', { 'lab-active': active('/lab') }]}>
      <img src="/icons/foillab-128.png" width="18" height="18" alt="" />
      foil<span class="lab-slash">/</span>lab
    </a>
    <div class="lab-links mono">
      <a href="/lab/challenges" class:list={[{ 'lab-active': active('/lab/challenges') }]}>challenges</a>
      <a href="/lab/scoreboard" class:list={[{ 'lab-active': active('/lab/scoreboard') }]}>scoreboard</a>
      <a href="/lab/certificate" class:list={[{ 'lab-active': active('/lab/certificate') }]}>certificate</a>
      <a href="/lab/about" class:list={[{ 'lab-active': active('/lab/about') }]}>about</a>
      <a href={github} target="_blank" rel="noopener" class="lab-cta">github ↗</a>
    </div>
  </div>
</nav>

<style>
.lab-nav {
  border-bottom: 1px solid rgba(77, 159, 255, 0.12);
  background: rgba(8, 9, 13, 0.6);
}
.lab-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 12px;
  padding-bottom: 12px;
}
.lab-brand {
  display: flex;
  align-items: center;
  gap: 8px;
  text-decoration: none;
  font-size: 13px;
  font-weight: 600;
  color: var(--foillab);
}
.lab-brand img { border-radius: 4px; }
.lab-slash { color: var(--dim); }
.lab-links {
  display: flex;
  align-items: center;
  gap: 22px;
  font-size: 12px;
  color: var(--muted);
}
.lab-links a { text-decoration: none; transition: color 0.15s; }
.lab-links a:hover { color: var(--text); }
.lab-links a.lab-active { color: var(--text); }
.lab-cta {
  color: var(--foillab) !important;
  border: 1px solid rgba(77, 159, 255, 0.25);
  padding: 5px 10px;
  border-radius: 5px;
  font-size: 11px;
  transition: border-color 0.15s;
}
.lab-cta:hover { border-color: var(--foillab) !important; }

@media (max-width: 640px) {
  .lab-links { gap: 14px; font-size: 11px; }
  .lab-cta { display: none; }
}
@media (max-width: 400px) {
  .lab-links a:not(.lab-cta) { display: none; }
}
</style>
