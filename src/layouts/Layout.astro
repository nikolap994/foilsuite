---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "FoilSuite — security tooling, built in layers",
  description = "A growing suite of focused security tools for detection, training, and protection. Open source.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/icons/foilsuite-48.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Manrope:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --accent: #41d07f;
    --bg: #08090d;
    --panel: #0b0d12;
    --text: #e8ebf0;
    --muted: #9aa3b2;
    --dim: #6f7888;
    --hair: rgba(255, 255, 255, 0.08);

    --foilguard: #41d07f;
    --foillab: #4d9fff;
    --foilvault: #b07cf0;
  }

  * {
    box-sizing: border-box;
  }
  html {
    scroll-behavior: smooth;
  }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: "Manrope", system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
  }
  a {
    color: inherit;
  }
  .mono {
    font-family: "JetBrains Mono", monospace;
  }
  .display {
    font-family: "Space Grotesk", sans-serif;
  }
</style>
