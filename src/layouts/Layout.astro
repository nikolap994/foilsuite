---
interface Props {
  title?: string
  description?: string
}
const {
  title = 'Foil — Security Tools Suite',
  description = 'Three open-source security tools forming one unified ecosystem: FoilGuard, FoilLab, and FoilVault.',
} = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" sizes="16x16" href="/icons/foilsuite-16.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/icons/foilsuite-48.png" />
    <link rel="icon" type="image/png" sizes="128x128" href="/icons/foilsuite-128.png" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --bg: #060d1f;
    --surface: #0c1530;
    --surface-2: #111f3f;
    --border: rgba(59, 130, 246, 0.12);
    --border-hover: rgba(59, 130, 246, 0.3);
    --brand: #3b82f6;
    --brand-dim: rgba(59, 130, 246, 0.1);
    --text: #e2e8f0;
    --text-muted: #94a3b8;
    --text-dim: #4a6080;
    --green: #10b981;
    --green-bg: rgba(16, 185, 129, 0.1);
    --amber: #f59e0b;
    --amber-bg: rgba(245, 158, 11, 0.1);
    --purple: #8b5cf6;
    --purple-bg: rgba(139, 92, 246, 0.1);
    --radius: 10px;
  }

  html {
    background-color: var(--bg);
    color: var(--text);
    font-family:
      -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue',
      sans-serif;
    font-size: 16px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    scroll-behavior: smooth;
  }

  body {
    min-height: 100vh;
    overflow-x: hidden;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  ::selection {
    background: var(--brand);
    color: #fff;
  }
</style>
