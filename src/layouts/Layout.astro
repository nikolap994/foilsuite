---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}
const {
  title = "FoilSuite — security tooling, built in layers",
  description = "A growing suite of focused security tools for detection, training, and protection. Open source.",
  ogImage = "https://foilsuite.netlify.app/og-default.png",
} = Astro.props;
const canonicalTitle = title.includes('FoilSuite') ? title : `${title} — FoilSuite`
const siteUrl = "https://foilsuite.netlify.app"
const repo = "https://github.com/nikolap994/foilsuite"
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={`${siteUrl}${Astro.url.pathname}`} />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${siteUrl}${Astro.url.pathname}`} />
    <meta property="og:title" content={canonicalTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={canonicalTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" type="image/png" href="/icons/foilsuite-48.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Manrope:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{canonicalTitle}</title>
  </head>
  <body>
    <nav class="site-nav">
      <div class="shell nav-inner">
        <a href="/" class="brand mono">
          <img src="/icons/foilsuite-128.png" alt="" width="24" height="24" />
          foil<span class="slash">/</span>suite
        </a>
        <div class="nav-links mono">
          <a href="/#modules">modules</a>
          <a href="/lab">lab</a>
          <a href="/blog">blog</a>
          <a href="/status">status</a>
          <a href={repo} class="nav-cta" target="_blank" rel="noopener">github ↗</a>
        </div>
      </div>
    </nav>

    <slot />

    <footer class="site-footer">
      <div class="shell foot-inner mono">
        <div class="foot-left">
          <span class="foot-brand">
            <img src="/icons/foilsuite-128.png" alt="" width="18" height="18" />
            foil/suite
          </span>
          <span class="foot-copy">© 2026 · <a href={repo}>github.com/nikolap994</a></span>
        </div>
        <nav class="foot-nav">
          <a href="https://github.com/nikolap994/foilguard" target="_blank" rel="noopener">FoilGuard</a>
          <a href="/lab">FoilLab</a>
          <a href="https://github.com/nikolap994/foilvault" target="_blank" rel="noopener">FoilVault</a>
          <span class="foot-sep">·</span>
          <a href="/blog">Blog</a>
          <a href="/status">Status</a>
          <span class="foot-sep">·</span>
          <a href="https://github.com/nikolap994/foilguard/blob/master/LICENSE" target="_blank" rel="noopener">MIT</a>
          <a href="https://github.com/nikolap994/foillab/blob/master/LICENSE" target="_blank" rel="noopener">AGPL-3.0</a>
        </nav>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --accent: #41d07f;
    --bg: #08090d;
    --panel: #0b0d12;
    --text: #e8ebf0;
    --muted: #9aa3b2;
    --dim: #6f7888;
    --hair: rgba(255, 255, 255, 0.08);

    --foilguard: #41d07f;
    --foillab: #4d9fff;
    --foilvault: #b07cf0;

    --mono: "JetBrains Mono", "Menlo", "Consolas", monospace;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: "Manrope", system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
  }
  a { color: inherit; }

  .mono { font-family: "JetBrains Mono", monospace; }
  .display { font-family: "Space Grotesk", sans-serif; }

  .shell {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 40px;
  }

  /* ── Site nav ── */
  .site-nav {
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    background: rgba(8, 9, 13, 0.92);
    backdrop-filter: blur(8px);
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 18px;
    padding-bottom: 18px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    font-weight: 600;
    font-size: 15px;
    letter-spacing: 0.02em;
    color: var(--text);
  }
  .brand img { border-radius: 6px; }
  .slash { color: var(--dim); }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 28px;
    font-size: 13px;
    color: var(--muted);
  }
  .nav-links a { text-decoration: none; transition: color 0.15s; }
  .nav-links a:hover { color: var(--text); }
  .nav-cta {
    color: #08090d !important;
    background: var(--text);
    font-weight: 600;
    padding: 8px 14px;
    border-radius: 6px;
    transition: background 0.15s;
  }
  .nav-cta:hover { background: var(--accent) !important; }

  /* ── Site footer ── */
  .site-footer {
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    margin-top: 80px;
    padding: 32px 0;
  }
  .foot-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px 32px;
  }
  .foot-left {
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
  }
  .foot-brand {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--muted);
  }
  .foot-brand img { border-radius: 4px; }
  .foot-copy { font-size: 12px; color: var(--dim); }
  .foot-copy a { color: var(--muted); text-decoration: none; }
  .foot-copy a:hover { color: var(--accent); }
  .foot-nav {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    font-size: 12px;
    color: var(--dim);
  }
  .foot-nav a { color: var(--dim); text-decoration: none; transition: color 0.15s; }
  .foot-nav a:hover { color: var(--accent); }
  .foot-sep { color: var(--hair); }

  /* ── Blog post shared styles ── */
  .post-page { padding-top: 40px; padding-bottom: 80px; max-width: 720px; }
  .breadcrumb { font-size: 12px; color: var(--dim); margin-bottom: 32px; }
  .breadcrumb a { text-decoration: none; color: var(--dim); }
  .breadcrumb a:hover { color: var(--accent); }
  .post-header { margin-bottom: 40px; }
  .post-meta { display: flex; gap: 14px; font-size: 11px; color: var(--dim); margin-bottom: 16px; flex-wrap: wrap; }
  .post-cat { color: var(--accent); font-weight: 600; letter-spacing: 0.08em; }
  .post-header h1 { font-size: 2rem; font-weight: 800; letter-spacing: -0.02em; line-height: 1.3; margin: 0; }
  .post-body { display: flex; flex-direction: column; }
  .post-body .lead-para { font-size: 17px; color: var(--muted); line-height: 1.8; margin-bottom: 36px; }
  .post-body h2 { font-size: 1.25rem; font-weight: 700; margin: 36px 0 14px; }
  .post-body p { font-size: 15px; color: var(--muted); line-height: 1.8; margin-bottom: 16px; }
  .post-body ul, .post-body ol { padding-left: 22px; display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px; }
  .post-body li { font-size: 15px; color: var(--muted); line-height: 1.7; }
  .post-body li strong { color: var(--text); }
  .post-body strong { color: var(--text); }
  .post-body code { background: rgba(0, 0, 0, 0.3); padding: 1px 5px; border-radius: 3px; font-size: 13px; color: var(--accent); font-family: "JetBrains Mono", monospace; }
  .post-body a { color: var(--accent); text-decoration: underline; text-decoration-color: rgba(65, 208, 127, 0.3); }
  .post-body .code-block {
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid var(--hair);
    border-radius: 8px;
    padding: 20px;
    margin: 20px 0;
    overflow-x: auto;
  }
  .post-body .code-block code { background: none; padding: 0; color: #a5b4fc; font-size: 13px; white-space: pre; }
  .post-footer {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--hair);
    font-size: 13px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .post-footer a { text-decoration: none; color: var(--dim); transition: color 0.15s; }
  .post-footer a:hover { color: var(--accent); }
  .post-footer .cta-link { color: var(--accent); font-weight: 600; margin-left: auto; }

  /* ── Badge chips (used in challenge pages) ── */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border: 1px solid transparent;
  }
  .badge-easy   { background: rgba(65,208,127,0.1); color: #41d07f; border-color: rgba(65,208,127,0.2); }
  .badge-medium { background: rgba(251,191,36,0.1); color: #fbbf24; border-color: rgba(251,191,36,0.2); }
  .badge-hard   { background: rgba(239,68,68,0.1);  color: #ef4444; border-color: rgba(239,68,68,0.2); }
  .badge-cat    { background: rgba(255,255,255,0.05); color: var(--muted); border-color: var(--hair); font-weight: 400; text-transform: none; letter-spacing: 0; }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .shell { padding: 0 20px; }
    .nav-links { gap: 16px; font-size: 12px; }
    .nav-cta { padding: 6px 12px !important; }
    .post-header h1 { font-size: 1.5rem; }
    .post-body .lead-para { font-size: 15px; }
  }
  @media (max-width: 400px) {
    .nav-links a:not(.nav-cta) { display: none; }
  }
</style>
