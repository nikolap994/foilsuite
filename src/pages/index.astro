---
import Layout from "../layouts/Layout.astro";

const repo = "https://github.com/nikolap994/foilsuite";

const products = [
  {
    name: "FoilGuard",
    icon: "/icons/foilguard-128.png",
    tag: "Browser Extension",
    desc: "Blocks typosquatting, homoglyph attacks, combosquatting, and newly-registered domains before the page loads. Enterprise policy support built in.",
    signals: ["typosquatting", "homoglyphs", "combosquatting", "digit substitution", "new domains", "subdomain abuse"],
    color: "var(--foilguard)",
    phase: "Phase 1",
    status: "Active",
    dot: "#41d07f",
    github: "https://github.com/nikolap994/foilguard",
  },
  {
    name: "FoilLab",
    icon: "/icons/foillab-128.png",
    tag: "CTF Platform",
    desc: "Weekly network & IoT capture-the-flag challenges with complete write-ups. Train against realistic targets.",
    color: "var(--foillab)",
    phase: "Phase 2",
    status: "Live",
    dot: "#41d07f",
    github: "https://github.com/nikolap994/foillab",
    live: "https://foillab.netlify.app",
  },
  {
    name: "FoilVault",
    icon: "/icons/foilvault-128.png",
    tag: "Password Manager",
    desc: "Zero-knowledge browser password manager. AES-GCM 256-bit encryption, TOTP, autofill, breach detection — all local, no server.",
    color: "var(--foilvault)",
    phase: "Phase 3",
    status: "Active",
    dot: "#41d07f",
    github: "https://github.com/nikolap994/foilvault",
  },
];
---

<Layout>
  <div class="page">
    <div class="grid-layer" aria-hidden="true"></div>
    <div class="glow" aria-hidden="true"></div>

    <div class="shell">
      <!-- nav -->
      <nav class="nav">
        <a href="/" class="brand">
          <img src="/icons/foilsuite-128.png" alt="" width="28" height="28" />
          <span class="mono">foil<span class="slash">/</span>suite</span>
        </a>
        <div class="nav-links mono">
          <a href="#modules">modules</a>
          <a href="#roadmap">roadmap</a>
          <a href="/blog">blog</a>
          <a href="/status">status</a>
          <a href={repo} class="nav-cta">github ↗</a>
        </div>
      </nav>

      <!-- hero -->
      <header class="hero">
        <div>
          <a href="#modules" class="badge mono">
            <span class="pulse"></span>
            FoilGuard 0.4 is live
            <span class="badge-pill">new →</span>
          </a>
          <h1 class="display">Security tooling,<br />built in layers.</h1>
          <p class="lead">
            A growing suite of focused tools for detection, training, and
            protection. Open source. No noise — just the layer between you and
            the threat.
          </p>
          <div class="cta-row">
            <a href="https://github.com/nikolap994/foilguard/releases" class="btn btn-primary mono">↓ install FoilGuard free</a>
            <a href="#modules" class="btn btn-ghost mono">$ explore the suite</a>
          </div>
        </div>

        <!-- manifest panel -->
        <div class="panel">
          <div class="panel-bar">
            <span class="tl" style="background:#ef6f6f"></span>
            <span class="tl" style="background:#e3b341"></span>
            <span class="tl" style="background:#41d07f"></span>
            <span class="panel-title mono">~/foil-suite — status</span>
          </div>
          <div class="panel-body">
            {
              products.map((p) => (
                <div class="status-row">
                  <img src={p.icon} alt="" width="32" height="32" />
                  <div class="status-name">
                    <div class="mono name">{p.name}</div>
                    <div class="mono tag">{p.tag}</div>
                  </div>
                  <div class="status-badge mono">
                    <span class="dot" style={`background:${p.dot}`} />
                    {p.status}
                  </div>
                </div>
              ))
            }
            <div class="panel-foot mono">4 modules · all live · open source</div>
          </div>
        </div>
      </header>

      <!-- modules -->
      <section id="modules" class="section">
        <div class="section-head">
          <div class="mono label">## modules</div>
          <div class="section-sub display">Three tools, one protective layer.</div>
        </div>
        <div class="cards">
          {
            products.map((p) => (
              <a href={'live' in p && p.live ? p.live : p.github} target="_blank" rel="noopener noreferrer" class="card" style={`--c:${p.color}`}>
                <span class="card-bar" />
                <div class="card-top">
                  <img src={p.icon} alt="" width="36" height="36" />
                  <span class="mono card-tag">{p.tag}</span>
                </div>
                <h3 class="display card-name">{p.name}</h3>
                <p class="card-desc">{p.desc}</p>
                {p.signals && (
                  <div class="card-signals">
                    {p.signals.map((s: string) => <span class="signal-chip mono">{s}</span>)}
                  </div>
                )}
                <div class="card-foot mono">
                  <span>{p.phase}</span>
                  <span class="card-status">
                    <span class="dot" style={`background:${p.dot}`} />
                    {p.status}
                  </span>
                </div>
              </a>
            ))
          }
        </div>
      </section>

      <!-- roadmap -->
      <section id="roadmap" class="section">
        <div class="mono label">## roadmap</div>
        <h2 class="display roadmap-title">Shipping in deliberate phases.</h2>
        <p class="roadmap-lead">
          Each tool is hardened before the next begins — no half-built surfaces
          to attack.
        </p>
        <div class="roadmap">
          {
            products.map((p) => (
              <a href={p.github} target="_blank" rel="noopener noreferrer" class="road-row" style={`--c:${p.color}`}>
                <span class="mono road-phase">{p.phase}</span>
                <span class="road-node" />
                <span class="display road-name">{p.name}</span>
                <span class="road-desc">{p.desc}</span>
                <span class="status-badge mono road-status">
                  <span class="dot" style={`background:${p.dot}`} />
                  {p.status}
                </span>
              </a>
            ))
          }
        </div>
      </section>

      <!-- closing cta -->
      <section class="closing">
        <div>
          <h3 class="display">Foil the attack.</h3>
          <p>
            Follow the build, file an issue, or star the repo — the suite grows
            in the open.
          </p>
        </div>
        <a href={repo} class="btn btn-primary mono nowrap">★ star on github</a>
      </section>

      <!-- changelog -->
      <section id="changelog" class="section changelog-section">
        <div class="mono label">## changelog</div>
        <h2 class="display changelog-title">Recent updates.</h2>
        <div class="changelog-list">
          <div class="cl-entry">
            <span class="cl-date mono">2026-06-28</span>
            <div class="cl-body">
              <strong>FoilGuard 0.4</strong> — Visit history trust, phishing path signals, high-risk TLD expansion (.zip, .download), redirect chain detection, daily badge counter, side panel context menu, false positive reports, allowlist expiry tracking
            </div>
          </div>
          <div class="cl-entry">
            <span class="cl-date mono">2026-06-21</span>
            <div class="cl-body">
              <strong>FoilGuard 0.3</strong> — Popup blocker, chrome.storage.sync migration, export/import settings, quick-allow from popup, mobile subdomain normalization, remote domain list sync
            </div>
          </div>
          <div class="cl-entry">
            <span class="cl-date mono">2026-06-14</span>
            <div class="cl-body">
              <strong>FoilLab 0.2</strong> — Ghost Protocol hard challenge (DNS TTL covert channel, 300pts), hint timer gate, challenge ratings, scoreboard, dedicated challenges page with filters
            </div>
          </div>
          <div class="cl-entry">
            <span class="cl-date mono">2026-06-07</span>
            <div class="cl-body">
              <strong>FoilLab 0.1</strong> — CTF platform launched with Silent Channel and Phantom Heartbeat challenges. FoilSuite website live at foilsuite.netlify.app
            </div>
          </div>
        </div>
        <a href={`${repo}/releases`} class="cl-all mono" target="_blank" rel="noopener">all releases on GitHub ↗</a>
      </section>

      <!-- footer -->
      <footer class="footer mono">
        <div class="foot-left">
          <span class="foot-brand">
            <img src="/icons/foilsuite-128.png" alt="" width="20" height="20" />
            foil/suite
          </span>
          <span class="foot-copy">© 2026 · <a href={repo}>github.com/nikolap994</a></span>
        </div>
        <nav class="foot-nav">
          <a href="https://github.com/nikolap994/foilguard" target="_blank" rel="noopener">FoilGuard</a>
          <a href="https://foillab.netlify.app" target="_blank" rel="noopener">FoilLab</a>
          <a href="https://github.com/nikolap994/foilvault" target="_blank" rel="noopener">FoilVault</a>
          <span class="foot-sep">·</span>
          <a href="/blog">Blog</a>
          <a href="/status">Status</a>
          <span class="foot-sep">·</span>
          <a href="https://github.com/nikolap994/foilguard/blob/master/LICENSE" target="_blank" rel="noopener">MIT</a>
          <a href="https://github.com/nikolap994/foillab/blob/master/LICENSE" target="_blank" rel="noopener">AGPL-3.0</a>
        </nav>
      </footer>
    </div>
  </div>
</Layout>

<style>
  .page {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
  }
  .grid-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: linear-gradient(rgba(255, 255, 255, 0.026) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.026) 1px, transparent 1px);
    background-size: 46px 46px;
    -webkit-mask-image: radial-gradient(1100px 700px at 70% 0%, #000 0%, transparent 75%);
    mask-image: radial-gradient(1100px 700px at 70% 0%, #000 0%, transparent 75%);
  }
  .glow {
    position: absolute;
    top: -220px;
    right: -120px;
    width: 720px;
    height: 520px;
    pointer-events: none;
    background: radial-gradient(circle at 60% 40%, var(--accent), transparent 65%);
    opacity: 0.13;
    filter: blur(40px);
  }
  .shell {
    position: relative;
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 40px;
  }

  /* nav */
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 26px 0;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 11px;
    text-decoration: none;
    font-weight: 600;
    font-size: 16px;
    letter-spacing: 0.02em;
  }
  .brand img {
    border-radius: 7px;
  }
  .slash {
    color: var(--dim);
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 30px;
    font-size: 13px;
    color: var(--muted);
  }
  .nav-links a {
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-links a:hover {
    color: var(--accent);
  }
  .nav-cta {
    color: #08090d !important;
    background: var(--text);
    font-weight: 600;
    padding: 9px 16px;
    border-radius: 7px;
    transition: background 0.2s;
  }
  .nav-cta:hover {
    background: var(--accent);
  }

  /* hero */
  .hero {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 54px;
    align-items: center;
    padding: 84px 0 80px;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    text-decoration: none;
    font-size: 12px;
    color: #cdd4e0;
    padding: 6px 6px 6px 14px;
    border-radius: 100px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.02);
  }
  .pulse {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #41d07f;
    box-shadow: 0 0 9px #41d07f;
  }
  .badge-pill {
    background: rgba(255, 255, 255, 0.06);
    padding: 3px 9px;
    border-radius: 100px;
    color: var(--muted);
  }
  h1.display {
    font-weight: 700;
    font-size: 58px;
    line-height: 1.04;
    letter-spacing: -0.03em;
    margin: 24px 0 0;
  }
  .lead {
    font-size: 17.5px;
    line-height: 1.65;
    color: var(--muted);
    max-width: 460px;
    margin: 22px 0 0;
  }
  .cta-row {
    display: flex;
    gap: 13px;
    margin-top: 34px;
  }
  .btn {
    text-decoration: none;
    padding: 14px 24px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 14px;
    transition: 0.2s;
  }
  .btn-primary {
    background: var(--accent);
    color: #06130b;
  }
  .btn-ghost {
    color: var(--text);
    font-weight: 500;
    border: 1px solid rgba(255, 255, 255, 0.16);
  }
  .btn-ghost:hover {
    border-color: rgba(255, 255, 255, 0.34);
  }
  .nowrap {
    white-space: nowrap;
  }
  .meta {
    display: flex;
    gap: 20px;
    margin-top: 30px;
    font-size: 12px;
    color: var(--dim);
  }

  /* panel */
  .panel {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 12px;
    overflow: hidden;
    background: var(--panel);
    box-shadow: 0 40px 80px -34px rgba(0, 0, 0, 0.85);
  }
  .panel-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 14px 17px;
    border-bottom: 1px solid var(--hair);
    background: rgba(255, 255, 255, 0.02);
  }
  .tl {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .panel-title {
    font-size: 12px;
    color: var(--dim);
    margin-left: 8px;
  }
  .panel-body {
    padding: 6px 0;
  }
  .status-row {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 18px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }
  .status-name {
    flex: 1;
    min-width: 0;
  }
  .status-name .name {
    font-size: 14px;
    font-weight: 600;
  }
  .status-name .tag {
    font-size: 11.5px;
    color: var(--dim);
  }
  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11.5px;
    color: #aeb6c4;
    padding: 5px 11px;
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }
  .panel-foot {
    padding: 13px 18px;
    font-size: 12px;
    color: #4f5666;
  }

  /* sections */
  .section {
    padding: 28px 0 8px;
  }
  #roadmap {
    padding-top: 64px;
  }
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    border-top: 1px solid var(--hair);
    padding-top: 34px;
  }
  .label {
    font-size: 13px;
    color: var(--dim);
    letter-spacing: 0.04em;
  }
  .section-sub {
    font-size: 15px;
    color: var(--muted);
  }
  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-top: 24px;
  }
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 26px;
    padding-top: 29px;
    border-radius: 10px;
    background: var(--panel);
    border: 1px solid rgba(255, 255, 255, 0.09);
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s;
    text-decoration: none;
    color: inherit;
  }
  .card:hover {
    border-color: rgba(255, 255, 255, 0.22);
    transform: translateY(-3px);
  }
  .card-bar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--c);
  }
  .card-top {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .card-tag {
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c);
  }
  .card-name {
    font-weight: 600;
    font-size: 21px;
    margin: 17px 0 0;
  }
  .card-desc {
    font-size: 14px;
    line-height: 1.6;
    color: var(--muted);
    margin: 10px 0 0;
  }
  .card-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 22px;
    padding-top: 18px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    font-size: 12px;
    color: var(--dim);
  }
  .card-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #aeb6c4;
  }
  .card-signals {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 14px;
  }
  .signal-chip {
    font-size: 10px;
    letter-spacing: 0.04em;
    color: var(--c);
    background: color-mix(in srgb, var(--c) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--c) 25%, transparent);
    border-radius: 4px;
    padding: 3px 8px;
  }

  /* roadmap */
  .roadmap-title {
    font-weight: 600;
    font-size: 24px;
    letter-spacing: -0.01em;
    margin: 10px 0 4px;
  }
  .roadmap-lead {
    font-size: 15px;
    color: var(--muted);
    margin: 0 0 22px;
  }
  .roadmap {
    border: 1px solid var(--hair);
    border-radius: 11px;
    overflow: hidden;
  }
  .road-row {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 20px 24px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(255, 255, 255, 0.012);
    text-decoration: none;
    color: inherit;
    transition: background 0.2s;
  }
  .road-row:hover {
    background: rgba(255, 255, 255, 0.04);
  }
  .road-phase {
    font-size: 13px;
    color: var(--c);
    width: 64px;
    flex-shrink: 0;
  }
  .road-node {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--c);
    box-shadow: 0 0 10px var(--c);
    flex-shrink: 0;
  }
  .road-name {
    font-weight: 600;
    font-size: 16px;
    width: 140px;
    flex-shrink: 0;
  }
  .road-desc {
    flex: 1;
    font-size: 14px;
    color: var(--muted);
    min-width: 0;
  }
  .road-status {
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* closing */
  .closing {
    margin-top: 72px;
    padding: 48px 44px;
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.09);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.005));
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 30px;
    flex-wrap: wrap;
  }
  .closing h3 {
    font-weight: 700;
    font-size: 26px;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .closing p {
    font-size: 15px;
    color: var(--muted);
    margin: 8px 0 0;
    max-width: 460px;
  }

  /* changelog */
  .changelog-section { padding-bottom: 80px; }
  .changelog-title { font-size: 2.4rem; font-weight: 800; letter-spacing: -0.03em; margin: 16px 0 36px; }
  .changelog-list { display: flex; flex-direction: column; gap: 0; border-left: 2px solid var(--hair); padding-left: 24px; margin-bottom: 24px; }
  .cl-entry { display: grid; grid-template-columns: 120px 1fr; gap: 16px; padding: 16px 0; border-bottom: 1px solid var(--hair); }
  .cl-entry:last-child { border-bottom: none; }
  .cl-date { font-size: 12px; color: var(--dim); padding-top: 2px; }
  .cl-body { font-size: 14px; color: var(--muted); line-height: 1.6; }
  .cl-body strong { color: var(--text); font-weight: 600; }
  .cl-all { font-size: 12px; color: var(--dim); text-decoration: none; transition: color 0.15s; }
  .cl-all:hover { color: var(--accent); }
  @media (max-width: 600px) {
    .cl-entry { grid-template-columns: 1fr; gap: 4px; }
    .changelog-title { font-size: 1.8rem; }
  }

  /* footer */
  .footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 34px 0 40px;
    margin-top: 40px;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    font-size: 13px;
    color: var(--dim);
    flex-wrap: wrap;
    gap: 16px 30px;
  }
  .foot-left {
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
  }
  .foot-brand {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    color: var(--muted);
  }
  .foot-brand img {
    border-radius: 5px;
  }
  .foot-copy { color: var(--dim); }
  .foot-nav {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .foot-sep { color: var(--hair); }
  .footer a {
    color: var(--dim);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer a:hover {
    color: var(--accent);
  }

  @media (max-width: 880px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 56px 0;
    }
    h1.display {
      font-size: 44px;
    }
    .cards {
      grid-template-columns: 1fr;
    }
    .road-row {
      flex-wrap: wrap;
      gap: 10px 16px;
    }
    .road-desc {
      flex-basis: 100%;
      order: 5;
    }
  }

  @media (max-width: 640px) {
    .shell { padding: 0 20px; }
    .nav { padding: 16px 0; }
    .nav-links { gap: 16px; font-size: 11px; }
    .nav-cta { padding: 7px 12px !important; font-size: 11px; }
    h1.display { font-size: 32px; line-height: 1.15; }
    .hero { padding: 40px 0 36px; gap: 28px; }
    .lead { font-size: 14px; }
    .cta-row { flex-direction: column; gap: 10px; }
    .cta-row .btn { text-align: center; }
    .footer-grid { grid-template-columns: 1fr; gap: 24px; }
