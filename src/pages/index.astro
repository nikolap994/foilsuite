---
import Layout from "../layouts/Layout.astro";

const repo = "https://github.com/nikolap994/foilsuite";

const products = [
  {
    name: "FoilGuard",
    icon: "/icons/foilguard-128.png",
    tag: "Browser Extension",
    desc: "Blocks typosquatting, homoglyph attacks, combosquatting, and newly-registered domains before the page loads. Enterprise policy support built in.",
    signals: ["typosquatting", "homoglyphs", "combosquatting", "digit substitution", "new domains", "subdomain abuse"],
    browsers: ["Chrome 114+", "Edge 114+", "Brave", "Opera"],
    color: "var(--foilguard)",
    phase: "Phase 1",
    status: "Active",
    dot: "#41d07f",
    github: "https://github.com/nikolap994/foilguard",
  },
  {
    name: "FoilLab",
    icon: "/icons/foillab-128.png",
    tag: "CTF Platform",
    desc: "Network forensics CTF platform — DNS exfiltration, beacon analysis, email spoofing, and more. Each challenge is based on a real attack pattern that FoilGuard detects.",
    signals: ["dns forensics", "beacon detection", "email spoofing", "log analysis", "pcap capture"],
    color: "var(--foillab)",
    phase: "Phase 2",
    status: "Active",
    dot: "#41d07f",
    github: "https://github.com/nikolap994/foilsuite",
    live: "/lab",
  },
  {
    name: "FoilVault",
    icon: "/icons/foilvault-128.png",
    tag: "Password Manager",
    desc: "Zero-knowledge browser password manager. AES-GCM 256-bit encryption, TOTP, autofill, breach detection — all local, no server.",
    signals: ["AES-GCM 256", "zero-knowledge", "local-first", "TOTP", "auto-lock", "HIBP breach check"],
    color: "var(--foilvault)",
    phase: "Phase 3",
    status: "Active",
    dot: "#41d07f",
    github: "https://github.com/nikolap994/foilvault",
  },
];
---

<Layout>
  <div class="page">
    <div class="grid-layer" aria-hidden="true"></div>
    <div class="glow" aria-hidden="true"></div>

    <div class="shell">
      <!-- hero -->
      <header class="hero">
        <div>
          <a href="#modules" class="badge mono">
            <span class="pulse"></span>
            FoilGuard 0.4 is live
            <span class="badge-pill">new →</span>
          </a>
          <h1 class="display">Security tooling,<br />built in layers.</h1>
          <p class="lead">
            A growing suite of focused tools for detection, training, and
            protection. Open source. No noise — just the layer between you and
            the threat.
          </p>
          <div class="cta-row">
            <a href="https://github.com/nikolap994/foilguard/releases" class="btn btn-primary mono">↓ install FoilGuard free</a>
            <a href="#modules" class="btn btn-ghost mono">$ explore the suite</a>
          </div>
        </div>

        <!-- manifest panel -->
        <div class="panel">
          <div class="panel-bar">
            <span class="tl" style="background:#ef6f6f"></span>
            <span class="tl" style="background:#e3b341"></span>
            <span class="tl" style="background:#41d07f"></span>
            <span class="panel-title mono">~/foil-suite — status</span>
          </div>
          <div class="panel-body">
            {
              products.map((p) => (
                <div class="status-row">
                  <img src={p.icon} alt="" width="32" height="32" />
                  <div class="status-name">
                    <div class="mono name">{p.name}</div>
                    <div class="mono tag">{p.tag}</div>
                  </div>
                  <div class="status-badge mono">
                    <span class="dot" style={`background:${p.dot}`} />
                    {p.status}
                  </div>
                </div>
              ))
            }
            <div class="panel-foot mono">3 modules · all live · open source</div>
          </div>
        </div>
      </header>

      <!-- modules -->
      <section id="modules" class="section">
        <div class="section-head">
          <div class="mono label">## modules</div>
          <div class="section-sub display">Three tools, one protective layer.</div>
        </div>
        <div class="cards">
          {
            products.map((p) => (
              <a href={'live' in p && p.live ? String(p.live) : p.github} target={!('live' in p && p.live) || String(p.live).startsWith('http') ? "_blank" : undefined} rel={!('live' in p && p.live) || String(p.live).startsWith('http') ? "noopener noreferrer" : undefined} class="card" style={`--c:${p.color}`}>
                <span class="card-bar" />
                <div class="card-top">
                  <img src={p.icon} alt="" width="36" height="36" />
                  <span class="mono card-tag">{p.tag}</span>
                </div>
                <h3 class="display card-name">{p.name}</h3>
                <p class="card-desc">{p.desc}</p>
                {p.signals && (
                  <div class="card-signals">
                    {p.signals.map((s: string) => <span class="signal-chip mono">{s}</span>)}
                  </div>
                )}
                {'browsers' in p && p.browsers && (
                  <div class="card-browsers mono">
                    {(p.browsers as string[]).map((b: string) => <span class="browser-chip">{b}</span>)}
                  </div>
                )}
                <div class="card-foot mono">
                  <span>{p.phase}</span>
                  <span class="card-status">
                    <span class="dot" style={`background:${p.dot}`} />
                    {p.status}
                  </span>
                </div>
              </a>
            ))
          }
        </div>
      </section>

      <!-- closing cta -->
      <section class="closing">
        <div>
          <h3 class="display">Foil the attack.</h3>
          <p>
            Follow the build, file an issue, or star the repo — the suite grows
            in the open.
          </p>
        </div>
        <a href={repo} class="btn btn-primary mono nowrap">★ star on github</a>
      </section>

    </div>
  </div>
</Layout>

<style>
  .page {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
  }
  .grid-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: linear-gradient(rgba(255, 255, 255, 0.026) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.026) 1px, transparent 1px);
    background-size: 46px 46px;
    -webkit-mask-image: radial-gradient(1100px 700px at 70% 0%, #000 0%, transparent 75%);
    mask-image: radial-gradient(1100px 700px at 70% 0%, #000 0%, transparent 75%);
  }
  .glow {
    position: absolute;
    top: -220px;
    right: -120px;
    width: 720px;
    height: 520px;
    pointer-events: none;
    background: radial-gradient(circle at 60% 40%, var(--accent), transparent 65%);
    opacity: 0.13;
    filter: blur(40px);
  }
  /* hero */
  .hero {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 54px;
    align-items: center;
    padding: 84px 0 80px;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    text-decoration: none;
    font-size: 12px;
    color: #cdd4e0;
    padding: 6px 6px 6px 14px;
    border-radius: 100px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.02);
  }
  .pulse {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #41d07f;
    box-shadow: 0 0 9px #41d07f;
  }
  .badge-pill {
    background: rgba(255, 255, 255, 0.06);
    padding: 3px 9px;
    border-radius: 100px;
    color: var(--muted);
  }
  h1.display {
    font-weight: 700;
    font-size: 58px;
    line-height: 1.04;
    letter-spacing: -0.03em;
    margin: 24px 0 0;
  }
  .lead {
    font-size: 17.5px;
    line-height: 1.65;
    color: var(--muted);
    max-width: 460px;
    margin: 22px 0 0;
  }
  .cta-row {
    display: flex;
    gap: 13px;
    margin-top: 34px;
  }
  .btn {
    text-decoration: none;
    padding: 14px 24px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 14px;
    transition: 0.2s;
  }
  .btn-primary {
    background: var(--accent);
    color: #06130b;
  }
  .btn-ghost {
    color: var(--text);
    font-weight: 500;
    border: 1px solid rgba(255, 255, 255, 0.16);
  }
  .btn-ghost:hover {
    border-color: rgba(255, 255, 255, 0.34);
  }
  .nowrap {
    white-space: nowrap;
  }
  .meta {
    display: flex;
    gap: 20px;
    margin-top: 30px;
    font-size: 12px;
    color: var(--dim);
  }

  /* panel */
  .panel {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 12px;
    overflow: hidden;
    background: var(--panel);
    box-shadow: 0 40px 80px -34px rgba(0, 0, 0, 0.85);
  }
  .panel-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 14px 17px;
    border-bottom: 1px solid var(--hair);
    background: rgba(255, 255, 255, 0.02);
  }
  .tl {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .panel-title {
    font-size: 12px;
    color: var(--dim);
    margin-left: 8px;
  }
  .panel-body {
    padding: 6px 0;
  }
  .status-row {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 18px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }
  .status-name {
    flex: 1;
    min-width: 0;
  }
  .status-name .name {
    font-size: 14px;
    font-weight: 600;
  }
  .status-name .tag {
    font-size: 11.5px;
    color: var(--dim);
  }
  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11.5px;
    color: #aeb6c4;
    padding: 5px 11px;
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }
  .panel-foot {
    padding: 13px 18px;
    font-size: 12px;
    color: #4f5666;
  }

  /* sections */
  .section {
    padding: 28px 0 8px;
  }
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    border-top: 1px solid var(--hair);
    padding-top: 34px;
  }
  .label {
    font-size: 13px;
    color: var(--dim);
    letter-spacing: 0.04em;
  }
  .section-sub {
    font-size: 15px;
    color: var(--muted);
  }
  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-top: 24px;
  }
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 26px;
    padding-top: 29px;
    border-radius: 10px;
    background: var(--panel);
    border: 1px solid rgba(255, 255, 255, 0.09);
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s;
    text-decoration: none;
    color: inherit;
  }
  .card:hover {
    border-color: rgba(255, 255, 255, 0.22);
    transform: translateY(-3px);
  }
  .card-bar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--c);
  }
  .card-top {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .card-tag {
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c);
  }
  .card-name {
    font-weight: 600;
    font-size: 21px;
    margin: 17px 0 0;
  }
  .card-desc {
    font-size: 14px;
    line-height: 1.6;
    color: var(--muted);
    margin: 10px 0 0;
  }
  .card-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 22px;
    padding-top: 18px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    font-size: 12px;
    color: var(--dim);
  }
  .card-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #aeb6c4;
  }
  .card-signals {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 14px;
  }
  .signal-chip {
    font-size: 10px;
    letter-spacing: 0.04em;
    color: var(--c);
    background: color-mix(in srgb, var(--c) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--c) 25%, transparent);
    border-radius: 4px;
    padding: 3px 8px;
  }
  .card-browsers {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 12px;
  }
  .browser-chip {
    font-size: 10px;
    letter-spacing: 0.03em;
    color: var(--dim);
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 4px;
    padding: 2px 7px;
  }

  /* closing */
  .closing {
    margin-top: 72px;
    padding: 48px 44px;
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.09);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.005));
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 30px;
    flex-wrap: wrap;
  }
  .closing h3 {
    font-weight: 700;
    font-size: 26px;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .closing p {
    font-size: 15px;
    color: var(--muted);
    margin: 8px 0 0;
    max-width: 460px;
  }

  @media (max-width: 880px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 56px 0;
    }
    h1.display {
      font-size: 44px;
    }
    .cards {
      grid-template-columns: 1fr;
    }
    .road-row {
      flex-wrap: wrap;
      gap: 10px 16px;
    }
    .road-desc {
      flex-basis: 100%;
      order: 5;
    }
  }

  @media (max-width: 640px) {
    h1.display { font-size: 32px; line-height: 1.15; }
    .hero { padding: 40px 0 36px; gap: 28px; }
    .lead { font-size: 14px; }
    .cta-row { flex-direction: column; gap: 10px; }
    .cta-row .btn { text-align: center; }
  }
</style>
