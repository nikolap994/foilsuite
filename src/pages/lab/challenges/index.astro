---
import Layout from '../../../layouts/Layout.astro'
import { challenges } from '../../../data/challenges'

const totalPts = challenges.reduce((s, c) => s + c.points, 0)
---
<Layout title="FoilLab Challenges" description="Browse all FoilLab CTF challenges — DNS forensics, packet analysis, email forensics and more.">
  <main class="shell challenges-page">
    <div class="page-header">
      <div class="mono label">## challenges</div>
      <h1>All Challenges</h1>
      <p class="page-lead">{challenges.length} challenges &nbsp;·&nbsp; {totalPts} total pts</p>
    </div>

    <div class="filter-bar mono">
      <div class="filter-group">
        <span class="filter-label">category:</span>
        <button class="filter-btn active" data-filter="cat" data-value="all">all</button>
        <button class="filter-btn" data-filter="cat" data-value="LOG FORENSICS">log</button>
        <button class="filter-btn" data-filter="cat" data-value="PACKET ANALYSIS">packet</button>
        <button class="filter-btn" data-filter="cat" data-value="EMAIL FORENSICS">email</button>
        <button class="filter-btn" data-filter="cat" data-value="THREAT INTEL">threat intel</button>
      </div>
      <div class="filter-group">
        <span class="filter-label">difficulty:</span>
        <button class="filter-btn active" data-filter="diff" data-value="all">all</button>
        <button class="filter-btn" data-filter="diff" data-value="easy">easy</button>
        <button class="filter-btn" data-filter="diff" data-value="medium">medium</button>
        <button class="filter-btn" data-filter="diff" data-value="hard">hard</button>
      </div>
    </div>

    <div class="challenges-grid" id="challenges-grid">
      {challenges.map(c => (
        <a
          href={`/lab/challenges/${c.id}`}
          class="ch-card"
          data-cat={c.category}
          data-diff={c.difficulty}
          data-id={c.id}
        >
          <div class="ch-top">
            <span class={`ch-diff diff-${c.difficulty}`}>{c.difficulty}</span>
            <span class="ch-cat mono">{c.category}</span>
            <span class="ch-solved-badge" style="display:none">✓</span>
          </div>
          <h2 class="ch-title">{c.title}</h2>
          <p class="ch-desc">{c.description.slice(0, 120)}{c.description.length > 120 ? '…' : ''}</p>
          <div class="ch-bottom mono">
            <span class="ch-pts">{c.points} pts</span>
          </div>
        </a>
      ))}
    </div>

    <p id="no-results" class="no-results mono hidden">no challenges match those filters</p>
  </main>

  <script>
    type FilterState = { cat: string; diff: string }
    const state: FilterState = { cat: 'all', diff: 'all' }
    const grid = document.getElementById('challenges-grid')!
    const noResults = document.getElementById('no-results')!
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.ch-card'))

    function applyFilters(): void {
      let visible = 0
      for (const card of cards) {
        const catMatch = state.cat === 'all' || card.dataset.cat === state.cat
        const diffMatch = state.diff === 'all' || card.dataset.diff === state.diff
        const show = catMatch && diffMatch
        card.classList.toggle('hidden', !show)
        if (show) visible++
      }
      noResults.classList.toggle('hidden', visible > 0)
    }

    document.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const type = btn.dataset.filter as 'cat' | 'diff'
        const value = btn.dataset.value!
        state[type] = value
        const group = btn.closest('.filter-group')!
        group.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'))
        btn.classList.add('active')
        applyFilters()
      })
    })

    for (const card of cards) {
      const id = card.dataset.id ?? (card as HTMLAnchorElement).href.split('/').pop()
      if (id && sessionStorage.getItem(`foillab_solved_${id}`)) {
        card.classList.add('ch-solved')
        const badge = card.querySelector<HTMLElement>('.ch-solved-badge')
        if (badge) badge.style.display = ''
      }
    }
  </script>
</Layout>

<style>
.challenges-page { padding-top: 40px; padding-bottom: 80px; }
.page-header { margin-bottom: 40px; }
.page-header h1 { font-size: 2.4rem; font-weight: 800; letter-spacing: -0.02em; margin: 16px 0 8px; }
.page-lead { color: var(--dim); font-size: 14px; }
.label { font-size: 12px; color: var(--dim); margin-bottom: 8px; }
.filter-bar { display: flex; flex-wrap: wrap; gap: 20px; margin-bottom: 36px; padding: 16px 20px; background: var(--panel); border: 1px solid var(--hair); border-radius: 8px; }
.filter-group { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.filter-label { font-size: 11px; color: var(--dim); white-space: nowrap; }
.filter-btn { background: none; border: 1px solid var(--hair); border-radius: 4px; padding: 4px 10px; font-size: 11px; color: var(--muted); cursor: pointer; transition: all 0.15s; font-family: var(--mono); }
.filter-btn:hover { border-color: rgba(65,208,127,0.3); color: var(--text); }
.filter-btn.active { border-color: var(--accent); color: var(--accent); background: rgba(65,208,127,0.06); }
.challenges-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 16px; }
.ch-card { display: block; background: var(--panel); border: 1px solid var(--hair); border-radius: 10px; padding: 22px; text-decoration: none; color: inherit; transition: border-color 0.15s, transform 0.15s; position: relative; overflow: hidden; }
.ch-card:hover { border-color: rgba(65,208,127,0.3); transform: translateY(-1px); }
.ch-card.ch-solved::after { content: '✓'; position: absolute; top: 14px; right: 16px; font-size: 14px; color: var(--accent); font-weight: 700; }
.ch-card.hidden { display: none; }
.ch-top { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
.ch-diff { font-size: 10px; font-weight: 700; padding: 3px 8px; border-radius: 3px; text-transform: uppercase; letter-spacing: 0.06em; }
.diff-easy { background: rgba(65,208,127,0.1); color: #41d07f; border: 1px solid rgba(65,208,127,0.2); }
.diff-medium { background: rgba(251,191,36,0.1); color: #fbbf24; border: 1px solid rgba(251,191,36,0.2); }
.diff-hard { background: rgba(239,68,68,0.1); color: #ef4444; border: 1px solid rgba(239,68,68,0.2); }
.ch-cat { font-size: 10px; color: var(--dim); letter-spacing: 0.06em; }
.ch-title { font-size: 18px; font-weight: 700; margin-bottom: 10px; color: var(--text); }
.ch-desc { font-size: 13px; color: var(--muted); line-height: 1.6; margin-bottom: 20px; flex: 1; }
.ch-bottom { display: flex; justify-content: space-between; font-size: 12px; }
.ch-pts { color: var(--accent); font-weight: 600; }
.no-results { text-align: center; padding: 48px; font-size: 13px; color: var(--dim); }
.hidden { display: none; }
@media (max-width: 600px) {
  .challenges-grid { grid-template-columns: 1fr; }
  .page-header h1 { font-size: 1.8rem; }
  .filter-bar { gap: 12px; padding: 14px 16px; }
}
</style>
