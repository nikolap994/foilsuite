---
import Layout from '../../layouts/Layout.astro'
import LabNav from '../../components/LabNav.astro'
import { challenges } from '../../data/challenges'
---
<Layout title="FoilLab Scoreboard" description="FoilLab challenge scoreboard — see who has solved the most challenges.">
  <LabNav />
  <main class="shell scoreboard-page">
    <div class="page-header">
      <h1 class="mono">— scoreboard</h1>
      <p class="sub">Rankings are stored locally in your browser. Solve challenges and submit your handle to appear here.</p>
    </div>

    <div class="sb-wrap">
      <table class="sb-table" id="sb-table">
        <thead>
          <tr>
            <th class="mono col-rank">#</th>
            <th class="mono col-name">player</th>
            <th class="mono col-pts">pts</th>
            <th class="mono col-solved">solved</th>
            <th class="mono col-time">last solve</th>
          </tr>
        </thead>
        <tbody id="sb-body">
          <tr id="empty-row">
            <td colspan="5" class="empty-cell">No scores yet — solve a challenge to be the first on the board.</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div id="sb-data" data-challenges={JSON.stringify(challenges.map(c => ({ id: c.id, title: c.title, pts: c.points })))} style="display:none"></div>
    <div class="sb-actions">
      <button id="clear-btn" class="clear-btn mono hidden">clear local scores</button>
      <button id="export-btn" class="export-btn mono hidden">export JSON ↓</button>
    </div>
  </main>

  <script>
    interface Entry { name: string; pts: number; solved: string[]; ts: number }
    interface ChallengeInfo { id: string; title: string; pts: number }

    const body = document.getElementById('sb-body')!
    const emptyRow = document.getElementById('empty-row')!
    const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement
    const sbData = document.getElementById('sb-data')!

    const challengeData: ChallengeInfo[] = JSON.parse(sbData.dataset.challenges ?? '[]')
    const CHALLENGE_MAP: Record<string, ChallengeInfo> = {}
    for (const c of challengeData) CHALLENGE_MAP[c.id] = c

    function relativeTime(ts: number): string {
      const diff = Date.now() - ts
      const m = Math.floor(diff / 60000)
      if (m < 1) return 'just now'
      if (m < 60) return `${m}m ago`
      const h = Math.floor(m / 60)
      if (h < 24) return `${h}h ago`
      return `${Math.floor(h / 24)}d ago`
    }

    function render(): void {
      const raw = localStorage.getItem('foillab_scoreboard')
      const entries: Entry[] = raw ? JSON.parse(raw) : []
      const sorted = [...entries].sort((a, b) => b.pts - a.pts || a.ts - b.ts)

      for (const tr of [...body.querySelectorAll('tr:not(#empty-row)')]) tr.remove()

      if (sorted.length === 0) {
        emptyRow.style.display = ''
        clearBtn.classList.add('hidden')
        return
      }

      emptyRow.style.display = 'none'
      clearBtn.classList.remove('hidden')

      sorted.forEach((entry, i) => {
        const tr = document.createElement('tr')
        tr.className = i === 0 ? 'row-first' : ''
        const solvedTitles = entry.solved.map(id => CHALLENGE_MAP[id]?.title ?? id).join(', ')
        tr.innerHTML = `
          <td class="mono col-rank">${i + 1}</td>
          <td class="col-name">${entry.name}</td>
          <td class="mono col-pts">${entry.pts}</td>
          <td class="col-solved">${solvedTitles}</td>
          <td class="mono col-time">${relativeTime(entry.ts)}</td>
        `
        body.appendChild(tr)
      })
    }

    clearBtn.addEventListener('click', () => {
      if (!confirm('Clear all local scores? This cannot be undone.')) return
      localStorage.removeItem('foillab_scoreboard')
      render()
    })

    const exportBtn = document.getElementById('export-btn') as HTMLButtonElement
    exportBtn.addEventListener('click', () => {
      const raw = localStorage.getItem('foillab_scoreboard') ?? '[]'
      const blob = new Blob([raw], { type: 'application/json' })
      const url = URL.createObjectURL(blob)
      const a = document.createElement('a')
      a.href = url
      a.download = `foillab-scores-${new Date().toISOString().slice(0, 10)}.json`
      a.click()
      URL.revokeObjectURL(url)
    })

    function renderWithExport(): void {
      render()
      const raw = localStorage.getItem('foillab_scoreboard')
      const hasEntries = raw && JSON.parse(raw).length > 0
      exportBtn.classList.toggle('hidden', !hasEntries)
    }
    renderWithExport()
  </script>
</Layout>

<style>
.scoreboard-page { padding-top: 48px; padding-bottom: 80px; }
.page-header { margin-bottom: 40px; }
h1 { font-size: 13px; color: var(--dim); font-weight: 400; letter-spacing: 0.05em; margin-bottom: 12px; }
.sub { color: var(--muted); font-size: 15px; }
.sb-actions { display: flex; gap: 10px; margin-top: 16px; flex-wrap: wrap; }
.export-btn {
  background: none; border: 1px solid var(--hair); border-radius: 6px;
  padding: 8px 14px; font-size: 12px; color: var(--dim); cursor: pointer; transition: border-color 0.15s, color 0.15s;
}
.export-btn:hover { border-color: rgba(65,208,127,0.4); color: var(--accent); }
.sb-wrap { background: var(--panel); border: 1px solid var(--hair); border-radius: 12px; overflow: hidden; }
.sb-table { width: 100%; border-collapse: collapse; font-size: 14px; }
.sb-table thead tr { border-bottom: 1px solid var(--hair); }
.sb-table th { text-align: left; padding: 14px 20px; font-size: 11px; color: var(--dim); font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; }
.sb-table tbody tr { border-bottom: 1px solid rgba(255,255,255,0.04); transition: background 0.15s; }
.sb-table tbody tr:last-child { border-bottom: none; }
.sb-table tbody tr:hover { background: rgba(255,255,255,0.025); }
.sb-table td { padding: 14px 20px; color: var(--muted); }
.col-rank { color: var(--dim); width: 48px; }
.col-name { font-weight: 600; color: var(--text); }
.col-pts { color: var(--accent); font-weight: 700; width: 80px; }
.col-solved { font-size: 13px; }
.col-time { color: var(--dim); font-size: 12px; width: 100px; }
.row-first td { color: var(--muted); }
.row-first .col-name::before { content: '★ '; color: var(--accent); }
.row-first .col-pts { color: var(--accent); }
.empty-cell { text-align: center; color: var(--dim); font-size: 14px; padding: 64px 20px; }
.clear-btn { background: none; border: 1px solid rgba(239,68,68,0.15); border-radius: 6px; color: var(--dim); cursor: pointer; font-size: 12px; padding: 7px 14px; transition: color 0.15s, border-color 0.15s; font-family: inherit; }
.clear-btn:hover { color: #ef4444; border-color: rgba(239,68,68,0.4); }
.hidden { display: none; }
@media (max-width: 600px) {
  .scoreboard-page { padding-top: 28px; padding-bottom: 48px; }
  .sb-wrap { overflow-x: auto; }
  .sb-table { min-width: 480px; }
  .col-time { display: none; }
  .sb-table th:last-child { display: none; }
}
</style>
