  author: 'Nikola Pavlović',
}
const description = 'A TTL covert channel hides binary data inside a field that nobody watches — the Time-to-Live value in DNS responses. This post explains how it works, why it bypasses most detection, and how to find it.'
---
<Layout title={post.title} description={description}>
  <main class="shell post-page">
