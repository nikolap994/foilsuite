.back-link:hover { color: var(--accent); }
.meta-sep { color: var(--dim); }
h1 { font-size: 2.4rem; font-weight: 800; letter-spacing: -0.03em; line-height: 1.2; margin-bottom: 20px; }
.post-lead { font-size: 17px; color: var(--muted); line-height: 1.6; margin-bottom: 40px; padding-bottom: 32px; border-bottom: 1px solid var(--hair); }
h2 { font-size: 1.3rem; font-weight: 700; margin: 36px 0 14px; }
p { color: var(--muted); line-height: 1.75; font-size: 15px; margin-bottom: 16px; }
ul, ol { color: var(--muted); line-height: 1.75; font-size: 15px; padding-left: 22px; margin-bottom: 16px; }
li { margin-bottom: 8px; }
strong { color: var(--text); }
a { color: var(--accent); text-decoration: none; }
a:hover { text-decoration: underline; }
