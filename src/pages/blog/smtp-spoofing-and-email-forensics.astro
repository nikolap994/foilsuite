.code-block {
  background: rgba(0,0,0,0.5); border: 1px solid var(--hair); border-radius: 8px;
  padding: 20px; margin: 20px 0; overflow-x: auto;
}
.code-block code { background: none; padding: 0; color: #a5b4fc; font-size: 13px; white-space: pre; }
.post-footer { margin-top: 48px; padding-top: 24px; border-top: 1px solid var(--hair); display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }
.tag { font-size: 11px; color: var(--dim); border: 1px solid var(--hair); border-radius: 20px; padding: 3px 10px; }
